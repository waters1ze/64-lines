generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(cuid())
  name              String?
  email             String         @unique
  passwordHash      String
  role              Role           @default(STUDENT)
  rating            Int            @default(1500)
  isPremium         Boolean        @default(false)
  premiumUntil      DateTime?
  teacherId         String?
  emailVerified     DateTime?
  verificationToken String?
  homeworks         Homework[]
  moduleAccesses    ModuleAccess[]
  purchases         Purchase[]
  analysisRequests  GameAnalysisRequest[]
  teacher           User?          @relation("TeacherStudents", fields: [teacherId], references: [id], onDelete: SetNull)
  students          User[]         @relation("TeacherStudents")
  sentMessages      Message[]      @relation("SentMessages")
  receivedMessages  Message[]      @relation("ReceivedMessages")
  teacherLiveSessions LiveSession[] @relation("TeacherLiveSessions")
  studentLiveSessions LiveSession[] @relation("StudentLiveSessions")
  teacherInvites      TeacherStudentInvite[] @relation("TeacherInvites")
  studentInvites      TeacherStudentInvite[] @relation("StudentInvites")
  puzzlesSolvedToday  Int            @default(0)
  lastPuzzleDate      DateTime?
  notifications       Notification[]
}

model Homework {
  id          String    @id @default(cuid())
  title       String
  pgn         String
  assignedAt  DateTime  @default(now())
  dueDate     DateTime?
  progress    Int       @default(0)
  solved      Boolean   @default(false)
  attempts    Int       @default(0)
  teacherNote String?
  studentId   String
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Course {
  id          String     @id @default(cuid())
  name        String
  description String
  price       Int
  imageUrl    String?
  createdAt   DateTime   @default(now())
  fileUrl     String?
  pgn         String?
  isPremium   Boolean    @default(false)
  purchases   Purchase[]
}

model Purchase {
  id         String   @id @default(cuid())
  userId     String
  courseId   String?
  moduleId   String?
  type       String   @default("COURSE") // COURSE, MODULE, SUBSCRIPTION, ANALYSIS
  createdAt  DateTime @default(now())
  status         String   @default("PENDING")
  paymentMethod  String   @default("sbp")
  comment        String?
  senderName String?
  course     Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module     Module?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Video {
  id        String   @id @default(cuid())
  title     String
  meta      String
  url       String
  isPremium Boolean @default(false)
  createdAt DateTime @default(now())
}

model Opening {
  id        String   @id @default(cuid())
  title     String
  pgn       String
  createdAt DateTime @default(now())
}

model InviteLink {
  id        String   @id @default(cuid())
  token     String   @unique
  role      Role
  teacherId String?
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Module {
  id          String         @id @default(cuid())
  title       String
  description String?
  tags        String[]
  visibility  String         @default("ALL")
  price       Int            @default(0)
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  lessons     Lesson[]
  accesses    ModuleAccess[]
  purchases   Purchase[]
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  videoUrl  String?
  fileUrl   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model ModuleAccess {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  grantedAt DateTime @default(now())
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model TeacherStudentInvite {
  id        String   @id @default(cuid())
  teacherId String
  studentId String
  // TEACHER_INVITED = учитель пригласил ученика
  // STUDENT_REQUESTED = ученик попросился к учителю
  direction String
  // PENDING, ACCEPTED, REJECTED
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  teacher User @relation("TeacherInvites", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentInvites", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([teacherId, studentId])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model LiveSession {
  id           String   @id @default(cuid())
  teacherId    String
  studentId    String
  status       String   @default("ACTIVE") // ACTIVE, ENDED
  jitsiRoomName String
  pgn          String?
  currentFen   String?
  activeMoveId String?
  lastUpdated  DateTime @default(now())
  createdAt    DateTime @default(now())

  teacher User @relation("TeacherLiveSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentLiveSessions", fields: [studentId], references: [id], onDelete: Cascade)
}

model Settings {
  id                String @id @default("global")
  subscriptionPrice Int    @default(300)
  analysisPrice     Int    @default(70)
}

model GameAnalysisRequest {
  id          String   @id @default(cuid())
  userId      String
  pgn         String
  comment     String?
  status      String   @default("PENDING") // PENDING, COMPLETED
  answerPgn   String?
  answerVideo String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Puzzle {
  id         String   @id
  fen        String
  moves      String
  rating     Int
  ratingDeviation Int @default(0)
  themes     String
  openingTags String?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

