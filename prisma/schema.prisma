generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                    @id @default(cuid())
  name                   String?
  email                  String                    @unique
  passwordHash           String
  role                   Role                      @default(STUDENT)
  rating                 Int                       @default(1500)
  isPremium              Boolean                   @default(false)
  premiumUntil           DateTime?
  teacherId              String?
  emailVerified          DateTime?
  verificationToken      String?
  homeworks              Homework[]
  moduleAccesses         ModuleAccess[]
  purchases              Purchase[]
  analysisRequests       GameAnalysisRequest[]
  teacher                User?                     @relation("TeacherStudents", fields: [teacherId], references: [id], onDelete: SetNull)
  students               User[]                    @relation("TeacherStudents")
  sentMessages           Message[]                 @relation("SentMessages")
  receivedMessages       Message[]                 @relation("ReceivedMessages")
  teacherLiveSessions    LiveSession[]             @relation("TeacherLiveSessions")
  studentLiveSessions    LiveSession[]             @relation("StudentLiveSessions")
  teacherInvites         TeacherStudentInvite[]    @relation("TeacherInvites")
  studentInvites         TeacherStudentInvite[]    @relation("StudentInvites")
  puzzlesSolvedToday     Int                       @default(0)
  lastPuzzleDate         DateTime?
  puzzlesSolvedTotal     Int                       @default(0)
  puzzlesAttempted       Int                       @default(0)
  activityStreak         Int                       @default(0)
  lastActivityDate       DateTime?
  dailyPuzzleStreak      Int                       @default(0)
  lastDailyPuzzleDate    String?                   // "YYYY-MM-DD" UTC
  premiumSource          String?                   // "PAID" | "REFERRAL" | "TRIAL" | null
  referralCode           String?                   @unique @default(cuid())
  referredById           String?
  referredBy             User?                     @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals              User[]                    @relation("Referrals")
  referralRewardsCount   Int                       @default(0)
  seasonRating           Int                       @default(1500)
  seasonPuzzlesSolved    Int                       @default(0)
  notifications          Notification[]
  solvedPuzzles          SolvedPuzzle[]
  pushSubscriptions      PushSubscription[]
  activityLogs           ActivityLog[]
  achievements           UserAchievement[]
  puzzleRushResults      PuzzleRushResult[]
  missedPuzzles          MissedPuzzle[]
  weakThemesAsStudent    StudentWeakThemesReport[] @relation("WeakThemesStudent")
  weakThemesAsTeacher    StudentWeakThemesReport[] @relation("WeakThemesTeacher")
  sentFriendRequests     FriendRequest[]           @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[]           @relation("ReceivedFriendRequests")
  createdMatches         PuzzleRushMatch[]            @relation("MatchCreator")
  matchParticipations    PuzzleRushMatchParticipant[] @relation("MatchParticipant")
  dailyPuzzleAttempts    DailyPuzzleAttempt[]
  activityEvents         ActivityEvent[]
  importedGames          ImportedGame[]
}

model Homework {
  id             String    @id @default(cuid())
  title          String
  pgn            String
  assignedAt     DateTime  @default(now())
  dueDate        DateTime?
  progress       Int       @default(0)
  solved         Boolean   @default(false)
  attempts       Int       @default(0)
  teacherNote    String?
  studentId      String
  rating         Int?
  student        User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reminderSentAt DateTime?
}

model Course {
  id          String     @id @default(cuid())
  name        String
  description String
  price       Int
  imageUrl    String?
  createdAt   DateTime   @default(now())
  fileUrl     String?
  pgn         String?
  isPremium   Boolean    @default(false)
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  purchases   Purchase[]
}

model Purchase {
  id            String   @id @default(cuid())
  userId        String
  courseId      String?
  moduleId      String?
  type          String   @default("COURSE") // COURSE, MODULE, SUBSCRIPTION, ANALYSIS
  amount        Int?
  createdAt     DateTime @default(now())
  status        String   @default("PENDING")
  paymentMethod String   @default("sbp")
  comment       String?
  senderName    String?
  course        Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module        Module?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Video {
  id            String    @id @default(cuid())
  title         String
  meta          String
  url           String
  isPremium     Boolean   @default(false)
  tags          String?   // puzzle themes space-separated: "fork pin skewer"
  createdAt     DateTime  @default(now())
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model Opening {
  id        String   @id @default(cuid())
  title     String
  pgn       String
  tags      String?  // puzzle themes space-separated: "fork pin skewer"
  createdAt DateTime @default(now())
}

model InviteLink {
  id        String   @id @default(cuid())
  token     String   @unique
  role      Role
  teacherId String?
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Module {
  id          String         @id @default(cuid())
  title       String
  description String?
  tags        String[]
  visibility  String         @default("ALL")
  price       Int            @default(0)
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  lessons     Lesson[]
  accesses    ModuleAccess[]
  purchases   Purchase[]
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  videoUrl  String?
  fileUrl   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model ModuleAccess {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  grantedAt DateTime @default(now())
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model TeacherStudentInvite {
  id        String   @id @default(cuid())
  teacherId String
  studentId String
  // TEACHER_INVITED = учитель пригласил ученика
  // STUDENT_REQUESTED = ученик попросился к учителю
  direction String
  // PENDING, ACCEPTED, REJECTED
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  teacher User @relation("TeacherInvites", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentInvites", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([teacherId, studentId])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model LiveSession {
  id            String   @id @default(cuid())
  teacherId     String
  studentId     String
  status        String   @default("ACTIVE") // ACTIVE, ENDED
  jitsiRoomName String
  pgn           String?
  currentFen    String?
  activeMoveId  String?
  lastUpdated   DateTime @default(now())
  createdAt     DateTime @default(now())

  teacher User @relation("TeacherLiveSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentLiveSessions", fields: [studentId], references: [id], onDelete: Cascade)
}

model Settings {
  id                String @id @default("global")
  subscriptionPrice Int    @default(300)
  analysisPrice     Int    @default(70)
}

model GameAnalysisRequest {
  id             String   @id @default(cuid())
  userId         String
  title          String?
  pgn            String
  comment        String?
  status         String   @default("PENDING") // PENDING, COMPLETED
  answerPgn      String?
  answerVideo    String?
  teacherComment String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Puzzle {
  id              String        @id
  fen             String
  moves           String
  rating          Int
  ratingDeviation Int           @default(0)
  themes          String
  openingTags     String?
  dailyPuzzles    DailyPuzzle[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  type      String?
  relatedId String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SolvedPuzzle {
  id       String   @id @default(cuid())
  userId   String
  puzzleId String
  solvedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, puzzleId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Achievement {
  id               String            @id @default(cuid())
  code             String            @unique
  title            String
  description      String
  icon             String
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model PuzzleRushResult {
  id       String   @id @default(cuid())
  userId   String
  score    Int
  playedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MissedPuzzle {
  id       String   @id @default(cuid())
  userId   String
  puzzleId String
  themes   String
  missedAt DateTime @default(now())
  resolved Boolean  @default(false)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, puzzleId])
}

model StudentWeakThemesReport {
  id                  String   @id @default(cuid())
  studentId           String
  teacherId           String
  themesJson          String
  recommendation      String
  recommendationsJson String?  // JSON: {recommendedVideos:[{id,title,reason}], recommendedOpenings:[{id,title,reason}]}
  generatedAt         DateTime @default(now())
  student             User     @relation("WeakThemesStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher             User     @relation("WeakThemesTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt  DateTime @default(now())
  sender     User     @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model PuzzleRushMatch {
  id          String   @id @default(cuid())
  creatorId   String
  status      String   @default("WAITING") // WAITING, ACTIVE, FINISHED, CANCELLED
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  creator     User     @relation("MatchCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participants PuzzleRushMatchParticipant[]
}

model PuzzleRushMatchParticipant {
  id          String   @id @default(cuid())
  matchId     String
  userId      String
  status      String   @default("INVITED") // INVITED, ACCEPTED, DECLINED, REMOVED
  score       Int?
  startedAt   DateTime?
  finishedAt  DateTime?

  match PuzzleRushMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User            @relation("MatchParticipant", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

model Season {
  id        String   @id @default(cuid())
  name      String
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean  @default(true)
}

model ImportedGame {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     String
  pgn          String
  playedAt     DateTime
  opponentName String
  result       String?
  createdAt    DateTime @default(now())
}

model DailyPuzzle {
  id       String @id @default(cuid())
  date     String @unique // "YYYY-MM-DD" UTC
  puzzleId String
  puzzle   Puzzle @relation(fields: [puzzleId], references: [id])
}

model DailyPuzzleAttempt {
  id          String   @id @default(cuid())
  userId      String
  date        String   // "YYYY-MM-DD" UTC
  solved      Boolean
  attemptedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model ActivityEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String   // PUZZLE_MILESTONE | ACHIEVEMENT | MATCH_WIN | STREAK_MILESTONE
  message   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tournament {
  id          String   @id @default(cuid())
  title       String
  description String?
  lichessUrl  String
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())
}

model Category {
  id        String   @id @default(cuid())
  name      String
  type      String   // "OPENING" | "VIDEO"
  createdAt DateTime @default(now())
  courses   Course[]
  videos    Video[]

  @@unique([name, type])
}
