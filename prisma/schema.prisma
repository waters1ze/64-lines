generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                    @id @default(cuid())
  name                   String?
  email                  String                    @unique
  passwordHash           String
  role                   Role                      @default(STUDENT)
  rating                 Int                       @default(1500)
  isPremium              Boolean                   @default(false)
  premiumUntil           DateTime?
  teacherId              String?
  emailVerified          DateTime?
  verificationToken      String?
  homeworks              Homework[]
  moduleAccesses         ModuleAccess[]
  purchases              Purchase[]
  analysisRequests       GameAnalysisRequest[]
  teacher                User?                     @relation("TeacherStudents", fields: [teacherId], references: [id], onDelete: SetNull)
  students               User[]                    @relation("TeacherStudents")
  sentMessages           Message[]                 @relation("SentMessages")
  receivedMessages       Message[]                 @relation("ReceivedMessages")
  teacherLiveSessions    LiveSession[]             @relation("TeacherLiveSessions")
  studentLiveSessions    LiveSession[]             @relation("StudentLiveSessions")
  teacherInvites         TeacherStudentInvite[]    @relation("TeacherInvites")
  studentInvites         TeacherStudentInvite[]    @relation("StudentInvites")
  puzzlesSolvedToday     Int                       @default(0)
  lastPuzzleDate         DateTime?
  puzzlesSolvedTotal     Int                       @default(0)
  puzzlesAttempted       Int                       @default(0)
  activityStreak         Int                       @default(0)
  lastActivityDate       DateTime?
  notifications          Notification[]
  solvedPuzzles          SolvedPuzzle[]
  pushSubscriptions      PushSubscription[]
  activityLogs           ActivityLog[]
  achievements           UserAchievement[]
  puzzleRushResults      PuzzleRushResult[]
  missedPuzzles          MissedPuzzle[]
  weakThemesAsStudent    StudentWeakThemesReport[] @relation("WeakThemesStudent")
  weakThemesAsTeacher    StudentWeakThemesReport[] @relation("WeakThemesTeacher")
  sentFriendRequests     FriendRequest[]           @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[]           @relation("ReceivedFriendRequests")
  createdDuels           PuzzleRushDuel[]          @relation("DuelCreator")
  opponentDuels          PuzzleRushDuel[]          @relation("DuelOpponent")
}

model Homework {
  id             String    @id @default(cuid())
  title          String
  pgn            String
  assignedAt     DateTime  @default(now())
  dueDate        DateTime?
  progress       Int       @default(0)
  solved         Boolean   @default(false)
  attempts       Int       @default(0)
  teacherNote    String?
  studentId      String
  rating         Int?
  student        User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reminderSentAt DateTime?
}

model Course {
  id          String     @id @default(cuid())
  name        String
  description String
  price       Int
  imageUrl    String?
  createdAt   DateTime   @default(now())
  fileUrl     String?
  pgn         String?
  isPremium   Boolean    @default(false)
  purchases   Purchase[]
}

model Purchase {
  id            String   @id @default(cuid())
  userId        String
  courseId      String?
  moduleId      String?
  type          String   @default("COURSE") // COURSE, MODULE, SUBSCRIPTION, ANALYSIS
  amount        Int?
  createdAt     DateTime @default(now())
  status        String   @default("PENDING")
  paymentMethod String   @default("sbp")
  comment       String?
  senderName    String?
  course        Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module        Module?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Video {
  id        String   @id @default(cuid())
  title     String
  meta      String
  url       String
  isPremium Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Opening {
  id        String   @id @default(cuid())
  title     String
  pgn       String
  createdAt DateTime @default(now())
}

model InviteLink {
  id        String   @id @default(cuid())
  token     String   @unique
  role      Role
  teacherId String?
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Module {
  id          String         @id @default(cuid())
  title       String
  description String?
  tags        String[]
  visibility  String         @default("ALL")
  price       Int            @default(0)
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  lessons     Lesson[]
  accesses    ModuleAccess[]
  purchases   Purchase[]
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  videoUrl  String?
  fileUrl   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model ModuleAccess {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  grantedAt DateTime @default(now())
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model TeacherStudentInvite {
  id        String   @id @default(cuid())
  teacherId String
  studentId String
  // TEACHER_INVITED = учитель пригласил ученика
  // STUDENT_REQUESTED = ученик попросился к учителю
  direction String
  // PENDING, ACCEPTED, REJECTED
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  teacher User @relation("TeacherInvites", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentInvites", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([teacherId, studentId])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model LiveSession {
  id            String   @id @default(cuid())
  teacherId     String
  studentId     String
  status        String   @default("ACTIVE") // ACTIVE, ENDED
  jitsiRoomName String
  pgn           String?
  currentFen    String?
  activeMoveId  String?
  lastUpdated   DateTime @default(now())
  createdAt     DateTime @default(now())

  teacher User @relation("TeacherLiveSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentLiveSessions", fields: [studentId], references: [id], onDelete: Cascade)
}

model Settings {
  id                String @id @default("global")
  subscriptionPrice Int    @default(300)
  analysisPrice     Int    @default(70)
}

model GameAnalysisRequest {
  id             String   @id @default(cuid())
  userId         String
  title          String?
  pgn            String
  comment        String?
  status         String   @default("PENDING") // PENDING, COMPLETED
  answerPgn      String?
  answerVideo    String?
  teacherComment String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Puzzle {
  id              String  @id
  fen             String
  moves           String
  rating          Int
  ratingDeviation Int     @default(0)
  themes          String
  openingTags     String?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SolvedPuzzle {
  id       String   @id @default(cuid())
  userId   String
  puzzleId String
  solvedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, puzzleId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Achievement {
  id               String            @id @default(cuid())
  code             String            @unique
  title            String
  description      String
  icon             String
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model PuzzleRushResult {
  id       String   @id @default(cuid())
  userId   String
  score    Int
  playedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MissedPuzzle {
  id       String   @id @default(cuid())
  userId   String
  puzzleId String
  themes   String
  missedAt DateTime @default(now())
  resolved Boolean  @default(false)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, puzzleId])
}

model StudentWeakThemesReport {
  id             String   @id @default(cuid())
  studentId      String
  teacherId      String
  themesJson     String
  recommendation String
  generatedAt    DateTime @default(now())
  student        User     @relation("WeakThemesStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher        User     @relation("WeakThemesTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt  DateTime @default(now())
  sender     User     @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model PuzzleRushDuel {
  id            String   @id @default(cuid())
  creatorId     String?
  opponentId    String?
  creatorScore  Int?
  opponentScore Int?
  status        String   @default("PENDING") // PENDING, COMPLETED
  createdAt     DateTime @default(now())

  creator  User? @relation("DuelCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  opponent User? @relation("DuelOpponent", fields: [opponentId], references: [id], onDelete: SetNull)
}
